# Copy to talos/env (gitignored), fill in, then `source talos/env` before
# running bootstrap.sh / proxmox.sh / gen-config.sh. Keeping this file
# current is what makes config regeneration reproducible.

export PROXMOX_SSH='root@pve.lan'
export NODE_IPS='10.5.6.11,10.5.6.12,10.5.6.13'
export VIP='10.5.6.10'
export API_DNS_NAME=     # optional DNS name for the VIP, added to API cert SANs
export GATEWAY='10.5.6.1'
export PREFIX=24
export DNS_SERVERS='1.1.1.1,9.9.9.9'

export CLUSTER_NAME=klube-pmx
export TALOS_VERSION=v1.13.6

export STORAGE=local-lvm
export SNIPPET_STORAGE=local
export BRIDGE=vmbr0
export VLAN_TAG=        # optional 802.1q tag if BRIDGE is a VLAN-aware trunk

# LoadBalancer IP pool for Cilium LB-IPAM (applied at bootstrap, never committed)
export LB_START=10.5.6.200
export LB_STOP=10.5.6.220
export VMID_BASE=800
export CP_CPU=4
export CP_MEM=8192
export CP_DISK=40       # OS disk (Talos EPHEMERAL: images, logs, emptyDir)
export DATA_DISK=100    # blank disk per node for Rook-Ceph; 0 to skip
