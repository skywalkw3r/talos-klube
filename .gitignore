# exclude mac thumbnail file
.DS_Store

# exclude helm chart .tgz files, The .tgz file is only required for the initial installation from our local machine. To avoid accidentally committing it
app/charts/**/charts

# exclude config files for k8
kubeconfig

# exclude config files for talos
talosconfig
talosctl

# legacy local scratch dir (root-anchored — app/bootstrap/ IS tracked)
/bootstrap/

# Talos machine configs and generated secrets — never commit these in plaintext
controlplane.yaml
worker.yaml
secrets.yaml
talsecret*.yaml
*secret*.yaml
*secret*.yml
*secrets*.yaml
_out/
clusterconfig/
talos/env
talos/.schematic-id

# SOPS / age key material — the age private key must never be committed
age.key
*.agekey
keys.txt

# SOPS-encrypted files ARE safe to commit
!*.sops.yaml
!*.sops.yml
